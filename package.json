{
    "name": "kodbank-ai-app",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "frontend",
        "backend"
    ],
    "scripts": {
        "build": "cd frontend && NODE_OPTIONS=--max-old-space-size=4096 GENERATE_SOURCEMAP=false CI=false npm run build",
        "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
        "dev:frontend": "npm start --workspace=frontend",
        "dev:backend": "npm run dev --workspace=backend",
        "install:all": "npm install"
    },
    "dependencies": {
        "bcryptjs": "^3.0.3",
        "compression": "^1.7.4",
        "cors": "^2.8.5",
        "dotenv": "^17.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^7.5.1",
        "express-validator": "^7.3.1",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "mammoth": "^1.11.0",
        "morgan": "^1.10.0",
        "multer": "^2.0.2",
        "pdf-parse": "^1.1.1",
        "pdf2json": "^4.0.2",
        "pg": "^8.11.3",
        "sqlite3": "^5.1.7",
        "tesseract.js": "^7.0.0",
        "winston": "^3.11.0",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}
